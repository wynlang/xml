// Exercises the shipped lib in src/xml.wyn via the tests/xml.wyn symlink.
import xml

test "get tag" {
    var doc = "<root><title>Hello World</title></root>"
    assert_eq(xml.xml_get_tag(doc, "title"), "Hello World")
}
test "get missing tag" {
    assert_eq(xml.xml_get_tag("<root></root>", "title"), "")
}
test "get attr" {
    var doc = "<item id=\"42\">Test</item>"
    assert_eq(xml.xml_get_attr(doc, "id"), "42")
}
test "get missing attr" {
    assert_eq(xml.xml_get_attr("<item>x</item>", "id"), "")
}
test "escape" {
    assert_eq(xml.xml_escape("<a>&\"</a>"), "&lt;a&gt;&amp;&quot;&lt;/a&gt;")
}
