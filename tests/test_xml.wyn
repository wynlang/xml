fn xml_get_tag(xml: string, tag: string) -> string {
    var open = "<" + tag + ">"
    var close = "</" + tag + ">"
    var start = -1
    for i in 0..xml.len() - open.len() {
        if xml.substring(i, i + open.len()) == open {
            start = i + open.len()
        }
    }
    if start == -1 { return "" }
    for i in start..xml.len() - close.len() + 1 {
        if xml.substring(i, i + close.len()) == close {
            return xml.substring(start, i)
        }
    }
    return ""
}

fn xml_escape(s: string) -> string {
    var out = s.replace("&", "&amp;")
    out = out.replace("<", "&lt;")
    out = out.replace(">", "&gt;")
    return out
}

fn main() -> int {
    assert_eq(xml_get_tag("<name>Alice</name>", "name"), "Alice")
    assert_eq(xml_get_tag("<root><x>1</x></root>", "x"), "1")
    assert_eq(xml_get_tag("<a>missing</b>", "c"), "")
    assert_eq(xml_escape("a < b & c > d"), "a &lt; b &amp; c &gt; d")
    
    println("xml: 4 tests passed")
    return 0
}
